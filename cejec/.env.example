# ==========================================
# CEJEC WEBSITE - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your values

# --- DATABASE ---
DATABASE_URL="postgresql://user:password@localhost:5432/cejec_db"
# For MongoDB: DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/cejec"

# --- NEXTAUTH (Authentication) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# --- CLOUDINARY (File Uploads) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- EMAIL (Nodemailer) ---
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="cejec@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="CEJEC <noreply@cejec.edu.ht>"
EMAIL_TO="admin@cejec.edu.ht"

# --- ADMIN ---
ADMIN_EMAIL="admin@cejec.edu.ht"
ADMIN_PASSWORD="change-this-in-production"

# --- SITE ---
NEXT_PUBLIC_SITE_URL="https://cejec.edu.ht"
NEXT_PUBLIC_SITE_NAME="CEJEC"
