// prisma/schema.prisma
// Run: npx prisma db push && npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
  activities Activity[]
}

enum Role {
  ADMIN
  EDITOR
}

// ─── CONTENT ─────────────────────────────────────────────────────────────────
model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String     @db.Text
  coverImage  String?
  category    PostCategory @default(NEWS)
  published   Boolean    @default(false)
  publishedAt DateTime?
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  tags        String[]
  views       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum PostCategory {
  NEWS
  PRESS_RELEASE
  MEDIA
  ACTIVITY
  BLOG
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  date        DateTime
  location    String?
  image       String?
  published   Boolean  @default(false)
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── GALLERY ─────────────────────────────────────────────────────────────────
model GalleryItem {
  id          String      @id @default(cuid())
  title       String
  url         String
  type        MediaType   @default(IMAGE)
  category    String?
  description String?
  published   Boolean     @default(true)
  createdAt   DateTime    @default(now())
}

enum MediaType {
  IMAGE
  VIDEO
}

// ─── STUDENTS ────────────────────────────────────────────────────────────────
model Student {
  id          String   @id @default(cuid())
  studentId   String   @unique
  firstName   String
  lastName    String
  email       String?
  program     String
  year        Int
  results     Result[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Result {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id])
  studentId   String
  semester    String
  year        Int
  subject     String
  grade       Float
  mention     String?
  createdAt   DateTime @default(now())
}

// ─── ADMISSIONS ──────────────────────────────────────────────────────────────
model Admission {
  id          String          @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  birthDate   DateTime
  program     String
  message     String?         @db.Text
  status      AdmissionStatus @default(PENDING)
  documents   String[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum AdmissionStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

// ─── CONTACT ─────────────────────────────────────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── NEWSLETTER ──────────────────────────────────────────────────────────────
model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── PROGRAMS ────────────────────────────────────────────────────────────────
model Program {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String   @db.Text
  duration    String
  level       String
  diploma     String
  requirements String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── PROFESSORS ──────────────────────────────────────────────────────────────
model Professor {
  id          String   @id @default(cuid())
  name        String
  title       String
  department  String
  bio         String?  @db.Text
  photo       String?
  email       String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── PARTNERS ────────────────────────────────────────────────────────────────
model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  website   String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── TESTIMONIALS ────────────────────────────────────────────────────────────
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  content   String   @db.Text
  photo     String?
  rating    Int      @default(5)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── STATS ───────────────────────────────────────────────────────────────────
model Stat {
  id    String @id @default(cuid())
  label String
  value String
  icon  String
  order Int    @default(0)
}
